RewriteEngine on

# Canonical host: strip www -> apex (any protocol), force HTTPS.
# 1) www.* -> https://play2wingames.com (single hop, both http + https)
RewriteCond %{HTTP_HOST} ^www\.play2wingames\.com$ [NC]
RewriteRule ^(.*)$ https://play2wingames.com/$1 [R=301,L]

# 2) Force HTTPS on the bare apex (proxy-aware: GoDaddy may terminate
#    SSL upstream and pass X-Forwarded-SSL: on, so check both).
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-SSL} !on
RewriteCond %{HTTP_HOST} ^play2wingames\.com$ [NC]
RewriteRule ^(.*)$ https://play2wingames.com/$1 [R=301,L]

# HTML must revalidate on every load ("no-cache" still allows ETag/304, so
# unchanged pages stay cheap). Without this Apache sends no Cache-Control
# and browsers heuristic-cache HTML — which repeatedly served stale JS on
# pairings-admin.html mid-tournament (inline scripts ride inside the HTML)
# and can leave players' phones on an outdated pairings.html. Push-to-deploy
# means a page is only stale until its next request — keep it that way.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
